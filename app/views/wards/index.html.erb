<h1>Wards</h1>

<table class="table table-striped">
  <thead>
    <tr>
      <th><%= link_to 'ID', wards_index_path(sort: 'id', direction: toggle_direction('id')) %></th>
      <th><%= link_to 'Ward Name', wards_index_path(sort: 'ward_name', direction: toggle_direction('ward_name')) %></th>
      <th><%= link_to 'Created At', wards_index_path(sort: 'created_at', direction: toggle_direction('created_at')) %></th>
    </tr>
  </thead>
  <tbody>
    <% @wards.each do |ward| %>
      <tr>
        <td><%= ward.id %></td>
        <td><%= ward.ward_name %></td>
        <td><%= ward.created_at.strftime("%Y-%m-%d %H:%M") %></td>
      </tr>
    <% end %>
  </tbody>
</table>
