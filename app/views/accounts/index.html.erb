<h1>Accounts</h1>

<table class="table table-striped">
  <thead>
    <tr>
      <th><%= link_to 'ID', accounts_index_path(sort: 'id', direction: toggle_direction('id')) %></th>
      <th><%= link_to 'Ward Name', accounts_index_path(sort: 'ward_name', direction: toggle_direction('ward_name')) %></th>
    </tr>
  </thead>
  <tbody>
    <% @accounts.each do |account| %>
      <tr>
        <td><%= account.id %></td>
        <td><%= account.ward_name %></td>
      </tr>
    <% end %>
  </tbody>
</table>