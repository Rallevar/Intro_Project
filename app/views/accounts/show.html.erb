<h1><%= @account.account_name %></h1>

<h2>Vendors Billed to This Account</h2>
<% if @account.vendors.any? %>
  <ul>
    <% @account.vendors.distinct.each do |vendor| %>
      <li><%= link_to vendor.vendor_name, vendor_path(vendor) %></li>
    <% end %>
  </ul>
<% else %>
  <p>No vendors found for this account.</p>
<% end %>

<%= link_to 'Back to Accounts', accounts_path %>
